{
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r --arg ts \"$(date +%s.%N)\" '\"\\($ts)\\tstart\\tmain\\t\\(.session_id // \"?\")\"' >> ~/claude_duty_cycle.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r --arg ts \"$(date +%s.%N)\" '\"\\($ts)\\tstop\\tmain\\t\\(.session_id // \"?\")\"' >> ~/claude_duty_cycle.log"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r --arg ts \"$(date +%s.%N)\" '\"\\($ts)\\tstart\\tsubagent:\\((.subagent_type // .agent_type // .tool_input.subagent_type // \"unknown\"))\\t\\(.session_id // \"?\")\"' >> ~/claude_duty_cycle.log"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r --arg ts \"$(date +%s.%N)\" '\"\\($ts)\\tstop\\tsubagent:\\((.subagent_type // .agent_type // \"unknown\"))\\t\\(.session_id // \"?\")\"' >> ~/claude_duty_cycle.log"
          }
        ]
      }
    ]
  }
}
