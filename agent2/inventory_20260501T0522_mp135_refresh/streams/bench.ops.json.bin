{
  "_control": {
    "doc": "Plan control verbs handled by the session runner.",
    "ops": {
      "barrier": {
        "args": {},
        "doc": "Add a barrier checkpoint to timeline.log.",
        "optional_args": {
          "tag": "ident"
        }
      },
      "delay": {
        "args": {
          "ms": "int"
        },
        "doc": "Sleep for ms milliseconds.",
        "optional_args": {}
      },
      "fork": {
        "args": {
          "name": "ident"
        },
        "doc": "Start a fork block; terminated by end.",
        "optional_args": {}
      },
      "inventory": {
        "args": {},
        "doc": "Return bench.devices.json and bench.ops.json streams. Defaults: refresh=true verify=false.",
        "optional_args": {
          "refresh": "bool",
          "verify": "bool"
        }
      },
      "join": {
        "args": {},
        "doc": "No-op; fork blocks join at end.",
        "optional_args": {}
      },
      "mark": {
        "args": {},
        "doc": "Add a named checkpoint to timeline.log.",
        "optional_args": {
          "tag": "ident"
        }
      },
      "wall_time": {
        "args": {},
        "doc": "Return bench.time.json with poller wall time.",
        "optional_args": {}
      }
    }
  },
  "bench_mcu": {
    "doc": "Small bench-helper MCU (STM32F405 wired to COMxx). '?' replies an identity string; 'r' pulses its D13 to reset whatever DUT is wired there.  Port comes from config.json instances; an autodetect VID/PID rule is honoured when the port field is omitted.",
    "ops": {
      "identify": {
        "args": {},
        "doc": "Send '?', capture reply to stream bench_mcu.identity.",
        "optional_args": {}
      },
      "reset_dut": {
        "args": {},
        "doc": "Send 'r' to assert D13 reset on the DUT.",
        "optional_args": {}
      },
      "send": {
        "args": {
          "data": "str"
        },
        "doc": "Send arbitrary bytes (escapes decoded: \\r \\n \\0 \\xNN), drain reply into stream bench_mcu.send.  Use for help ('h'), version ('v'), any one-shot bench-MCU command.",
        "optional_args": {}
      }
    }
  },
  "dfu": {
    "doc": "STM32 DFU bootloader programming via STM32_Programmer_CLI. Ops: list (enumerate DFU devices), flash (single file to address), flash_layout (TSV-described multi-partition, each row's Binary column is a plan @blob reference).  Binary path is bench-owned; attacker-controllable inputs are limited to typed plan args and plan blobs.",
    "ops": {
      "flash": {
        "args": {
          "address": "int",
          "image": "blob"
        },
        "doc": "Single-file flash to 0xADDRESS. Verify on.",
        "optional_args": {}
      },
      "flash_layout": {
        "args": {
          "layout": "blob"
        },
        "doc": "Multi-partition flash from a TSV flashlayout (see STM32CubeProgrammer docs).  Every Binary column must be @blobname; filesystem paths are rejected. no_reconnect=true kills cubeprog once 'Reconnecting the device' appears on stdout -- saves ~30 s per iteration when loading a SYSRAM-resident image that never re-enters DFU. Success requires 'RUNNING Program' seen first.",
        "optional_args": {
          "no_reconnect": "bool"
        }
      },
      "list": {
        "args": {},
        "doc": "Run cubeprog -l usb; append output to dfu.list stream; log parsed device list.",
        "optional_args": {}
      }
    }
  },
  "dsp": {
    "doc": "SHARC DSP over FT4222 QSPI master; expander reset; UART drain.",
    "ops": {
      "boot": {
        "args": {
          "ldr": "blob"
        },
        "doc": "Load LDR firmware via FT4222 QSPI boot path.",
        "optional_args": {}
      },
      "qspi_max_transfer_size": {
        "args": {
          "clk_div": "int",
          "mode": "int"
        },
        "doc": "Open master with these settings, query FT4222_GetMaxTransferSize(), log + stream the result. AN329: the value depends on bus speed, chip mode, and active function.",
        "optional_args": {
          "flags": "int"
        }
      },
      "qspi_read": {
        "args": {
          "chunk_size": "int",
          "clk_div": "int",
          "mode": "int",
          "n": "int"
        },
        "doc": "Raw QSPI master read; result appended to stream dsp.qspi_read. Same chunk semantics as qspi_write.",
        "optional_args": {}
      },
      "qspi_read_verify_prbs": {
        "args": {
          "chunk_size": "int",
          "clk_div": "int",
          "mode": "int",
          "n": "int",
          "seed": "int"
        },
        "doc": "Read n bytes, compare to xorshift32(seed); fails op on mismatch.",
        "optional_args": {}
      },
      "qspi_write": {
        "args": {
          "chunk_size": "int",
          "clk_div": "int",
          "data": "blob",
          "mode": "int"
        },
        "doc": "Raw QSPI master write of a blob. Data split into chunk_size-byte CS frames; single-lane mode keeps CS low across frames, multi-lane mode pulses CS per frame (caller owns framing). Optional prefix blob prepended to every multi-lane chunk; typical use is a single 0x00 byte to sidestep the FT4222 first-byte hazard (frames whose first byte has (B & 0x11) == 0x01 corrupt subsequent bytes). Ignored in single-lane mode.",
        "optional_args": {
          "prefix": "blob"
        }
      },
      "qspi_write_prbs": {
        "args": {
          "chunk_size": "int",
          "clk_div": "int",
          "mode": "int",
          "n": "int",
          "seed": "int"
        },
        "doc": "Write n bytes of xorshift32(seed) over QSPI. Same prefix semantics as qspi_write.",
        "optional_args": {
          "prefix": "blob"
        }
      },
      "qspi_xfer_prbs": {
        "args": {
          "chunk_size": "int",
          "clk_div": "int",
          "mode": "int",
          "n": "int",
          "seed": "int"
        },
        "doc": "Full-duplex xfer of xorshift32(seed); MISO goes into stream dsp.qspi_xfer. Single-lane only (mode=1). prefix is accepted for grammar symmetry but has no effect in single-lane.",
        "optional_args": {
          "prefix": "blob"
        }
      },
      "reset": {
        "args": {},
        "doc": "Pulse expander reset + reinit.",
        "optional_args": {}
      },
      "uart_close": {
        "args": {},
        "doc": "Stop UART capture.",
        "optional_args": {}
      },
      "uart_expect": {
        "args": {
          "sentinel": "str",
          "timeout_ms": "int"
        },
        "doc": "Block until sentinel appears in dsp.uart, then continue.  Pass end_session=true to short-circuit the rest of the plan.",
        "optional_args": {
          "end_session": "bool"
        }
      },
      "uart_open": {
        "args": {},
        "doc": "Start UART capture into dsp.uart.",
        "optional_args": {}
      },
      "uart_write": {
        "args": {
          "data": "str"
        },
        "doc": "Write to DSP UART byte-at-a-time. Python-style escapes decoded: \\r \\n \\t \\0 \\xNN etc.",
        "optional_args": {}
      }
    }
  },
  "fpga": {
    "doc": "iCEstick FPGA: program SPI flash via FT2232H MPSSE + UART.",
    "ops": {
      "program": {
        "args": {
          "bin": "blob"
        },
        "doc": "Erase, write, verify flash then release CRESET.",
        "optional_args": {}
      },
      "uart_close": {
        "args": {},
        "doc": "Stop FPGA UART capture.",
        "optional_args": {}
      },
      "uart_expect": {
        "args": {
          "sentinel": "str",
          "timeout_ms": "int"
        },
        "doc": "Block until sentinel in fpga.uart, then continue. Pass end_session=true to short-circuit the plan.",
        "optional_args": {
          "end_session": "bool"
        }
      },
      "uart_open": {
        "args": {},
        "doc": "Start FPGA UART capture.",
        "optional_args": {}
      },
      "uart_write": {
        "args": {
          "data": "str"
        },
        "doc": "Send bytes to FPGA UART (escapes decoded: \\r \\n \\t \\0 \\xNN). Requires uart_open first.",
        "optional_args": {}
      }
    }
  },
  "mp135": {
    "doc": "STM32MP135 eval board serial console via STLink VCP (configured in config.json, usually ST VID 0483 PID 3753 interface MI_01).  Background-drained into mp135.uart stream.",
    "ops": {
      "uart_close": {
        "args": {},
        "doc": "Stop capture, close port.",
        "optional_args": {}
      },
      "uart_expect": {
        "args": {
          "sentinel": "str",
          "timeout_ms": "int"
        },
        "doc": "Block until sentinel appears in mp135.uart, then continue.  Pass end_session=true to short-circuit the rest of the plan (old wait_uart semantics).",
        "optional_args": {
          "end_session": "bool"
        }
      },
      "uart_open": {
        "args": {},
        "doc": "Open console, start capture into mp135.uart.",
        "optional_args": {}
      },
      "uart_write": {
        "args": {
          "data": "str"
        },
        "doc": "Write to console. Python-style escapes decoded: \\r \\n \\t \\0 \\xNN etc.",
        "optional_args": {}
      }
    }
  },
  "msc": {
    "doc": "USB Mass Storage Class block-device writer. Probes for a configured VID/PID/iSerial, resolves the backing /dev/sdX, and writes or verifies blobs at LBA offsets.",
    "ops": {
      "read": {
        "args": {
          "n": "int"
        },
        "doc": "Read n bytes from the resolved block device starting at offset_lba (default 0); bytes go into stream msc.read in the artefact tarball.",
        "optional_args": {
          "offset_lba": "int"
        }
      },
      "verify": {
        "args": {
          "data": "blob"
        },
        "doc": "Read len(data) bytes from the resolved block device starting at offset_lba and compare byte-for-byte. Streams a window around the first mismatch into msc.verify_mismatch on failure.",
        "optional_args": {
          "offset_lba": "int"
        }
      },
      "write": {
        "args": {
          "data": "blob"
        },
        "doc": "Write a blob to the resolved block device. offset_lba defaults to 0; units are block_size (512 B for STM32MP1 baremetal MSC). Refuses if any partition under the device is mounted.",
        "optional_args": {
          "offset_lba": "int"
        }
      }
    }
  },
  "scope": {
    "doc": "Oscilloscope (VISA): trigger + capture a set of channels.",
    "ops": {
      "capture": {
        "args": {
          "chans": "str"
        },
        "doc": "Capture listed channels (e.g. chans=\"C1,C2\") as CSV into scope.csv stream. If config.json has a scope.signals table mapping channel -> {name, active_below}, scope:capture also logs per-channel transition counts + active duty in timeline.log (e.g. C2 DSP_FAULT: went_active=0 ...) and writes the full summary as JSON to the scope.summary stream. GET /scope/signals returns the current map.",
        "optional_args": {}
      }
    }
  },
  "ssh": {
    "doc": "SSH to fixed-IP embedded Linux; per-command ops exposed as ssh:run_<name>, each with a fixed schema. Key, known_hosts, IP are bench-owned. No free-form command passing.",
    "ops": {
      "run_date": {
        "args": {},
        "doc": "SSH target and run 'date -Iseconds'",
        "optional_args": {}
      },
      "run_df": {
        "args": {},
        "doc": "SSH target and run 'df -h'",
        "optional_args": {}
      },
      "run_dmesg_tail": {
        "args": {
          "n": "int"
        },
        "doc": "SSH target and run 'dmesg | tail -n {n}'",
        "optional_args": {}
      },
      "run_ls_log": {
        "args": {},
        "doc": "SSH target and run 'ls -la /var/log'",
        "optional_args": {}
      },
      "run_uname": {
        "args": {},
        "doc": "SSH target and run 'uname -a'",
        "optional_args": {}
      },
      "run_uptime": {
        "args": {},
        "doc": "SSH target and run 'uptime'",
        "optional_args": {}
      }
    }
  }
}
