   2.236  STREAM   bench.ops.json       '{\\n  "_control": {\\n    "doc": "Plan control verbs handled by the session runner.",\\n    "ops": {\\n      "barrier": {\\n        "args": {},\\n        "doc": "Add a barrier checkpoint to timeline.log.",\\n        "optional_args": {\\n          "tag": "ident"\\n        }\\n      },\\n      "delay": {\\n        "args": {\\n          "ms": "int"\\n        },\\n        "doc": "Sleep for ms milliseconds.",\\n        "optional_args": {}\\n      },\\n      "fork": {\\n        "args": {\\n          "name": "ident"\\n        },\\n        "doc": "Start a fork block; terminated by end.",\\n        "optional_args": {}\\n      },\\n      "inventory": {\\n        "args": {},\\n        "doc": "Return bench.devices.json and bench.ops.json streams. Defaults: refresh=true verify=false.",\\n        "optional_args": {\\n          "refresh": "bool",\\n          "verify": "bool"\\n        }\\n      },\\n      "join": {\\n        "args": {},\\n        "doc": "No-op; fork blocks join at end.",\\n        "optional_args": {}\\n      },\\n      "mark": {\\n        "args": {},\\n        "doc": "Add a named checkpoint to timeline.log.",\\n        "optional_args": {\\n          "tag": "ident"\\n        }\\n      },\\n      "wall_time": {\\n        "args": {},\\n        "doc": "Return bench.time.json with poller wall time.",\\n        "optional_args": {}\\n      }\\n    }\\n  },\\n  "bench_mcu": {\\n    "doc": "Small bench-helper MCU (STM32F405 wired to COMxx). \'?\' replies an identity string; \'r\' pulses its D13 to reset whatever DUT is wired there.  Port comes from config.json instances; an autodetect VID/PID rule is honoured when the port field is omitted.",\\n    "ops": {\\n      "identify": {\\n        "args": {},\\n        "doc": "Send \'?\', capture reply to stream bench_mcu.identity.",\\n        "optional_args": {}\\n      },\\n      "reset_dut": {\\n        "args": {},\\n        "doc": "Send \'r\' to assert D13 reset on the DUT.",\\n        "optional_args": {}\\n      },\\n      "send": {\\n        "args": {\\n          "data": "str"\\n        },\\n        "doc": "Send arbitrary bytes (escapes decoded: \\\\r \\\\n \\\\0 \\\\xNN), drain reply into stream bench_mcu.send.  Use for help (\'h\'), version (\'v\'), any one-shot bench-MCU command.",\\n        "optional_args": {}\\n      }\\n    }\\n  },\\n  "dfu": {\\n    "doc": "STM32 DFU bootloader programming via STM32_Programmer_CLI. Ops: list (enumerate DFU devices), flash (single file to address), flash_layout (TSV-described multi-partition, each row\'s Binary column is a plan @blob reference).  Binary path is bench-owned; attacker-controllable inputs are limited to typed plan args and plan blobs.",\\n    "ops": {\\n      "flash": {\\n        "args": {\\n          "address": "int",\\n          "image": "blob"\\n        },\\n        "doc": "Single-file flash to 0xADDRESS. Verify on.",\\n        "optional_args": {}\\n      },\\n      "flash_layout": {\\n        "args": {\\n          "layout": "blob"\\n        },\\n        "doc": "Multi-partition flash from a TSV flashlayout (see STM32CubeProgrammer docs).  Every Binary column must be @blobname; filesystem paths are rejected. no_reconnect=true kills cubeprog once \'Reconnecting the device\' appears on stdout -- saves ~30 s per iteration when loading a SYSRAM-resident image that never re-enters DFU. Success requires \'RUNNING Program\' seen first.",\\n        "optional_args": {\\n          "no_reconnect": "bool"\\n        }\\n      },\\n      "list": {\\n        "args": {},\\n        "doc": "Run cubeprog -l usb; append output to dfu.list stream; log parsed device list.",\\n        "optional_args": {}\\n      }\\n    }\\n  },\\n  "dsp": {\\n    "doc": "SHARC DSP over FT4222 QSPI master; expander reset; UART drain.",\\n    "ops": {\\n      "boot": {\\n        "args": {\\n          "ldr": "blob"\\n        },\\n        "doc": "Load LDR firmware via FT4222 QSPI boot path.",\\n        "optional_args": {}\\n      },\\n      "qspi_max_transfer_size": {\\n        "args": {\\n          "clk_div": "int",\\n          "mode": "int"\\n        },\\n        "doc": "Open master with these settings, query FT4222_GetMaxTransferSize(), log + stream the result. AN329: the value depends on bus speed, chip mode, and active function.",\\n        "optional_args": {\\n          "flags": "int"\\n        }\\n      },\\n      "qspi_read": {\\n        "args": {\\n          "chunk_size": "int",\\n          "clk_div": "int",\\n          "mode": "int",\\n          "n": "int"\\n        },\\n        "doc": "Raw QSPI master read; result appended to stream dsp.qspi_read. Same chunk semantics as qspi_write.",\\n        "optional_args": {}\\n      },\\n      "qspi_read_verify_prbs": {\\n        "args": {\\n          "chunk_size": "int",\\n          "clk_div": "int",\\n          "mode": "int",\\n          "n": "int",\\n          "seed": "int"\\n        },\\n        "doc": "Read n bytes, compare to xorshift32(seed); fails op on mismatch.",\\n        "optional_args": {}\\n      },\\n      "qspi_write": {\\n        "args": {\\n          "chunk_size": "int",\\n          "clk_div": "int",\\n          "data": "blob",\\n          "mode": "int"\\n        },\\n        "doc": "Raw QSPI master write of a blob. Data split into chunk_size-byte CS frames; single-lane mode keeps CS low across frames, multi-lane mode pulses CS per frame (caller owns framing). Optional prefix blob prepended to every multi-lane chunk; typical use is a single 0x00 byte to sidestep the FT4222 first-byte hazard (frames whose first byte has (B & 0x11) == 0x01 corrupt subsequent bytes). Ignored in single-lane mode.",\\n        "optional_args": {\\n          "prefix": "blob"\\n        }\\n      },\\n      "qspi_write_prbs": {\\n        "args": {\\n          "chunk_size": "int",\\n          "clk_div": "int",\\n          "mode": "int",\\n          "n": "int",\\n          "seed": "int"\\n        },\\n        "doc": "Write n bytes of xorshift32(seed) over QSPI. Same prefix semantics as qspi_write.",\\n        "optional_args": {\\n          "prefix": "blob"\\n        }\\n      },\\n      "qspi_xfer_prbs": {\\n        "args": {\\n          "chunk_size": "int",\\n          "clk_div": "int",\\n          "mode": "int",\\n          "n": "int",\\n          "seed": "int"\\n        },\\n        "doc": "Full-duplex xfer of xorshift32(seed); MISO goes into stream dsp.qspi_xfer. Single-lane only (mode=1). prefix is accepted for grammar symmetry but has no effect in single-lane.",\\n        "optional_args": {\\n          "prefix": "blob"\\n        }\\n      },\\n      "reset": {\\n        "args": {},\\n        "doc": "Pulse expander reset + reinit.",\\n        "optional_args": {}\\n      },\\n      "uart_close": {\\n        "args": {},\\n        "doc": "Stop UART capture.",\\n        "optional_args": {}\\n      },\\n      "uart_expect": {\\n        "args": {\\n          "sentinel": "str",\\n          "timeout_ms": "int"\\n        },\\n        "doc": "Block until sentinel appears in dsp.uart, then continue.  Pass end_session=true to short-circuit the rest of the plan.",\\n        "optional_args": {\\n          "end_session": "bool"\\n        }\\n      },\\n      "uart_open": {\\n        "args": {},\\n        "doc": "Start UART capture into dsp.uart.",\\n        "optional_args": {}\\n      },\\n      "uart_write": {\\n        "args": {\\n          "data": "str"\\n        },\\n        "doc": "Write to DSP UART byte-at-a-time. Python-style escapes decoded: \\\\r \\\\n \\\\t \\\\0 \\\\xNN etc.",\\n        "optional_args": {}\\n      }\\n    }\\n  },\\n  "fpga": {\\n    "doc": "iCEstick FPGA: program SPI flash via FT2232H MPSSE + UART.",\\n    "ops": {\\n      "program": {\\n        "args": {\\n          "bin": "blob"\\n        },\\n        "doc": "Erase, write, verify flash then release CRESET.",\\n        "optional_args": {}\\n      },\\n      "uart_close": {\\n        "args": {},\\n        "doc": "Stop FPGA UART capture.",\\n    