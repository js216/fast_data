{
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/log_event.sh '\"\\($ts)\\tstart\\t\\(.session_id // \"?\")\\tmain\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/log_event.sh '\"\\($ts)\\tstop\\t\\(.session_id // \"?\")\\tmain\"'"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/log_event.sh 'select((.subagent_type // .agent_type // .tool_input.subagent_type // \"\") != \"\") | \"\\($ts)\\tstart\\t\\(.session_id // \"?\")\\tsubagent:\\(.subagent_type // .agent_type // .tool_input.subagent_type)\"'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/log_event.sh 'select((.subagent_type // .agent_type // \"\") != \"\") | \"\\($ts)\\tstop\\t\\(.session_id // \"?\")\\tsubagent:\\(.subagent_type // .agent_type)\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/log_event.sh '\"\\($ts)\\ttool_pre\\t\\(.session_id // \"?\")\\t\\(.tool_name // \"?\")\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/bg_bash_wrap.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/log_event.sh '\"\\($ts)\\ttool_post\\t\\(.session_id // \"?\")\\t\\(.tool_name // \"?\")\"'"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh $HOME/fast_data/duty_cycle/log_event.sh '\"\\($ts)\\ttool_post\\t\\(.session_id // \"?\")\\t\\(.tool_name // \"?\")\"'"
          }
        ]
      }
    ]
  }
}
